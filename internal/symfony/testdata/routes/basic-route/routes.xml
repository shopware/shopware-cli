<?xml version="1.0" encoding="UTF-8" ?>
<routes xmlns="http://symfony.com/schema/routing"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/routing https://symfony.com/schema/routing/routing-1.0.xsd">
    <route id="frontend.example" path="/example/{page}" controller="Shop\Storefront\Controller\ExampleController::index" methods="GET|POST" schemes="https">
        <default key="page">1</default>
        <requirement key="page">\d+</requirement>
        <option key="seo">false</option>
        <condition>context.getMethod() in ['GET']</condition>
    </route>
</routes>
