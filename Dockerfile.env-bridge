FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG TARGETOS TARGETARCH
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -ldflags="-s -w" -o /env-bridge ./env-bridge/

FROM scratch

COPY --from=builder /env-bridge /env-bridge

ENTRYPOINT ["/env-bridge"]
